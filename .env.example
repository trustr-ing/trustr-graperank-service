# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# Bind address. Use 127.0.0.1 (default) when co-located with the orchestrator on
# the same droplet. Set to the droplet's VPC private IP (e.g. 10.x.x.x) or
# 0.0.0.0 when deployed on a separate droplet within the same DigitalOcean VPC.
HOST=0.0.0.0

# ── Service identity ──────────────────────────────────────────────────────────
# Must match TSM_SERVICE_N_SERVICE_ID in trustr-service-orchestrator.
SERVICE_ID=trustr_graperank

# ── Processing ────────────────────────────────────────────────────────────────
# Maximum results per output page (kind 37573)
PAGE_SIZE=1000

# If true, emit verbose kind 7000 info events during interpretation/calculation
VERBOSE_FEEDBACK=true

# ── Relay defaults (fallback when orchestrator payload omits defaults) ─────────
# Comma-separated read relays used for POV/event-resolution fetches.
# Orchestrator-provided defaultReadRelays take precedence per request.
READ_RELAYS=wss://relay.primal.net,wss://relay.damus.io

# ── Request config constraints (MVP) ────────────────────────────────────────────
# Allowed values for config:type in incoming requests and announcement metadata.
ALLOWED_REQUEST_TYPES=pubkey,p,P
# Default config:type advertised by service announcement.
DEFAULT_REQUEST_TYPE=p
