# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# Bind address. Use 127.0.0.1 (default) when co-located with the orchestrator on
# the same droplet. Set to the droplet's VPC private IP (e.g. 10.x.x.x) or
# 0.0.0.0 when deployed on a separate droplet within the same DigitalOcean VPC.
HOST=0.0.0.0

# ── Service identity ──────────────────────────────────────────────────────────
# Must match TSM_SERVICE_N_SERVICE_ID in trustr-service-orchestrator.
SERVICE_ID=trustr_graperank

# ── Processing ────────────────────────────────────────────────────────────────
# Maximum results per output page (kind 37573)
PAGE_SIZE=1000

# If true, emit verbose kind 7000 info events during interpretation/calculation
VERBOSE_FEEDBACK=true
